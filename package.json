{
  "name": "mdesign",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Claude Design — a project-based design workspace (gallery + chat/file workspace)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build:agent": "esbuild src/agent-main/index.ts --bundle --platform=node --format=esm --outfile=electron/agent.bundle.mjs --packages=external",
    "build:sidecar": "cargo build --release --manifest-path desktop/Cargo.toml",
    "dist:mac": "npm run build && npm run build:agent && npm run build:sidecar && electron-builder --mac",
    "electron": "electron .",
    "electron:dev": "ELECTRON_DEV=1 electron ."
  },
  "build": {
    "appId": "com.mdesign.app",
    "productName": "MDesign",
    "asar": false,
    "afterPack": "electron/afterPack.cjs",
    "files": ["electron/**/*", "package.json", "node_modules/**/*"],
    "extraResources": [{ "from": "desktop/target/release/mdesign", "to": "mdesign" }],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "desktop/MDesign.icns",
      "identity": null
    },
    "directories": { "output": "electron-dist" }
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "^0.80.2",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.456.0",
    "pdfjs-dist": "^3.11.174",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.27.0",
    "remark-gfm": "^4.0.0",
    "typebox": "^1.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
